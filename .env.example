# Copy this file to .env. Never commit the real .env file.
AWS_DEFAULT_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Production HTTPS entry point. Point this domain's A record to the EC2 Elastic IP.
PUBLIC_DOMAIN=election.example.com
CADDY_EMAIL=infra@example.com
CADDY_IMAGE=caddy:2-alpine

ELECTION_S3_BUCKET=bkk-election-images-party
ELECTION_S3_PREFIX=
OCR_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/000000000000/ocr-jobs-prod.fifo
UPDATE_QUEUE_URL=

HERMES_IMAGE=nousresearch/hermes-agent:latest
HERMES_RUNTIME_DIR=./runtime/hermes
HERMES_SHM_SIZE=1gb
HERMES_API_PORT=8642
HERMES_DASHBOARD_PORT=9119
HERMES_DASHBOARD=1
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=change-me
HERMES_DASHBOARD_BASIC_AUTH_SECRET=change-me
API_SERVER_ENABLED=true
API_SERVER_KEY=change-me
API_SERVER_CORS_ORIGINS=*
HERMES_MODEL=
OLLAMA_API_BASE=
OPENAI_API_BASE=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
MODEL_API_KEY=

LINE_CHANNEL_ACCESS_TOKEN=change-me
LINE_CHANNEL_SECRET=change-me
LINE_PUBLIC_URL=http://localhost:8646
LINE_RELAY_PORT=8646
LINE_LIFF_CORRECTION_ID=
LINE_ALLOW_ALL_USERS=false
LINE_ALLOWED_USERS=
LINE_ALLOWED_GROUPS=
LINE_ALLOWED_ROOMS=
LINE_HOME_CHANNEL=

OCR_WORKER_HERMES_MODEL=gemma4:26b
OCR_WORKER_MODEL_NAME=gemma4:26b
OCR_WORKER_QUEUE_MAX_MESSAGES=1
OCR_WORKER_PROCESSING_CONCURRENCY=1
OCR_WORKER_QUEUE_VISIBILITY_TIMEOUT=300

RESULTS_API_PORT=8080
RESULTS_API_SOURCE_ELECTION_ID=default
RESULTS_API_CORS_ORIGINS=*
RESULTS_API_KEY=
RESULTS_API_CANDIDATES_MANIFEST_URL=https://w3-dev.ch7.com/api-data/candidates/manifest.json
RESULTS_API_CANDIDATES_FEATURED_URL=https://w3-dev.ch7.com/api-data/candidates/featured.json
RESULTS_API_CANDIDATES_TIMEOUT_SECONDS=5
RESULTS_API_CANDIDATES_CACHE_SECONDS=300
RESULTS_API_DISTRICTS_URL=https://w3-dev.ch7.com/api-data/master-data/districts.json
RESULTS_API_DISTRICTS_TIMEOUT_SECONDS=5
RESULTS_API_DISTRICTS_CACHE_SECONDS=300
RESULTS_API_ELECTION_ID=bkk-governor-2026
RESULTS_API_ELECTION_TITLE=ผลการเลือกตั้งผู้ว่าฯ กรุงเทพมหานคร
RESULTS_API_RESULT_STATUS=LIVE_COUNT
RESULTS_API_DELAYED_AFTER_MINUTES=30

IMAGE_REGISTRY=election
IMAGE_TAG=local
