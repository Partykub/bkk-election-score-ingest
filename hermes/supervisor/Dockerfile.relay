FROM python:3.11-slim

WORKDIR /app

COPY ./hermes/supervisor/requirements.relay.txt /tmp/relay-requirements.txt
RUN pip install --no-cache-dir -r /tmp/relay-requirements.txt

COPY ./hermes /app/hermes

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1

CMD ["python", "-m", "hermes.supervisor.line_webhook_relay", "--host", "0.0.0.0", "--port", "8646"]
