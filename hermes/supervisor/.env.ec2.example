HERMES_SUPERVISOR_CONTAINER_NAME=hermes-supervisor
HERMES_SUPERVISOR_RUNTIME_DIR=./runtime-ec2
HERMES_SUPERVISOR_API_PORT=8642
HERMES_SUPERVISOR_DASHBOARD_PORT=9119
HERMES_SUPERVISOR_LINE_PORT=8646
HERMES_SUPERVISOR_SHM_SIZE=1gb
HERMES_DASHBOARD=1
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=change-this-password
HERMES_DASHBOARD_BASIC_AUTH_SECRET=change-this-session-secret
API_SERVER_ENABLED=false
API_SERVER_HOST=0.0.0.0
API_SERVER_KEY=change-this-api-key
API_SERVER_CORS_ORIGINS=*
LINE_CHANNEL_ACCESS_TOKEN=replace-with-line-channel-access-token
LINE_CHANNEL_SECRET=replace-with-line-channel-secret
LINE_HOST=0.0.0.0
LINE_PORT=8646
LINE_PUBLIC_URL=https://replace-with-public-line-url
LINE_ALLOWED_USERS=
LINE_ALLOWED_GROUPS=
LINE_ALLOWED_ROOMS=
LINE_ALLOW_ALL_USERS=false
LINE_HOME_CHANNEL=
LINE_SLOW_RESPONSE_THRESHOLD=45

# EC2 path keeps Hermes and Ollama inside Docker, but workflow state still
# lands in S3 through the supervisor relay and workers.
OLLAMA_CONTAINER_NAME=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=gemma4:26b
OLLAMA_DATA_DIR=./ollama/data
SUPERVISOR_STORAGE_BACKEND=s3
SUPERVISOR_S3_BUCKET=replace-with-s3-bucket
SUPERVISOR_S3_REGION=ap-southeast-1
SUPERVISOR_S3_ENDPOINT=
SUPERVISOR_S3_PREFIX=api-data/score
OCR_WORKER_CONTAINER_NAME=ocr-worker
OCR_WORKER_HERMES_BASE_URL=http://hermes-supervisor:8642
OCR_WORKER_HERMES_API_KEY=change-this-api-key
OCR_WORKER_HERMES_MODEL=hermes-agent
OCR_WORKER_QUEUE_URL=
OCR_WORKER_AWS_REGION=ap-southeast-1
OCR_WORKER_S3_BUCKET=
OCR_WORKER_S3_PREFIX=api-data/score
OCR_WORKER_QUEUE_VISIBILITY_TIMEOUT=300
SUPERVISOR_OCR_QUEUE_URL=
SUPERVISOR_OCR_QUEUE_REGION=ap-southeast-1
SUPERVISOR_OCR_QUEUE_NAME=ocr-jobs.fifo
SUPERVISOR_OCR_LANGUAGE_HINT=th
SUPERVISOR_OCR_DOCUMENT_TYPE=election_score_sheet
SUPERVISOR_OCR_PROMPT_VERSION=ocr-v1
OCR_WORKER_MODEL_NAME=gemma4:26b
UPDATE_WORKER_CONTAINER_NAME=update-worker
UPDATE_WORKER_QUEUE_URL=
UPDATE_WORKER_AWS_REGION=ap-southeast-1
UPDATE_WORKER_S3_BUCKET=
UPDATE_WORKER_S3_PREFIX=api-data/score
UPDATE_WORKER_TARGET_API_BASE_URL=
UPDATE_WORKER_QUEUE_VISIBILITY_TIMEOUT=300
SUPERVISOR_UPDATE_QUEUE_URL=
SUPERVISOR_UPDATE_QUEUE_REGION=ap-southeast-1
SUPERVISOR_UPDATE_QUEUE_NAME=update-jobs.fifo
