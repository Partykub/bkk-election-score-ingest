AWS_DEFAULT_REGION=ap-southeast-1
# Leave AWS credentials blank when the EC2 instance role already has S3/SQS access.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Temporary public hostname until infra provides a real domain.
PUBLIC_DOMAIN=54.254.164.95.sslip.io
# Must be a real email address; ACME rejects placeholder domains like example.com.
CADDY_EMAIL=CHANGE_ME_REAL_EMAIL
CADDY_IMAGE=caddy:2-alpine

ELECTION_S3_BUCKET=ch7-static-bkkelection2569
ELECTION_S3_PREFIX=api-data/score
OCR_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/511996147186/election-ocr-jobs-prod.fifo
UPDATE_QUEUE_URL=

HERMES_IMAGE=nousresearch/hermes-agent:latest
HERMES_RUNTIME_DIR=/opt/election-data/hermes-runtime
HERMES_SHM_SIZE=1gb
HERMES_API_PORT=8642
HERMES_DASHBOARD_PORT=9119
HERMES_DASHBOARD=1
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=CHANGE_ME_DASHBOARD_PASSWORD
HERMES_DASHBOARD_BASIC_AUTH_SECRET=CHANGE_ME_DASHBOARD_SECRET
API_SERVER_ENABLED=true
API_SERVER_KEY=CHANGE_ME_API_SERVER_KEY
API_SERVER_CORS_ORIGINS=*
# Match the current dev env example: OpenRouter + Claude Sonnet 4.6.
# Change to `bedrock` to use AWS Bedrock via IAM or AWS_BEARER_TOKEN_BEDROCK.
HERMES_PROVIDER=openrouter
HERMES_MODEL=anthropic/claude-sonnet-4.6
OLLAMA_API_BASE=
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENROUTER_API_KEY=CHANGE_ME_OPENROUTER_API_KEY
MODEL_API_KEY=
AWS_BEARER_TOKEN_BEDROCK=

LINE_CHANNEL_ACCESS_TOKEN=CHANGE_ME_LINE_CHANNEL_ACCESS_TOKEN
LINE_CHANNEL_SECRET=CHANGE_ME_LINE_CHANNEL_SECRET
LINE_PUBLIC_URL=https://54.254.164.95.sslip.io
LINE_RELAY_PORT=8646
LINE_LIFF_CORRECTION_ID=
LINE_ALLOW_ALL_USERS=false
LINE_ALLOWED_USERS=
LINE_ALLOWED_GROUPS=
LINE_ALLOWED_ROOMS=
LINE_HOME_CHANNEL=

OCR_WORKER_HERMES_MODEL=anthropic/claude-sonnet-4.6
OCR_WORKER_MODEL_NAME=anthropic/claude-sonnet-4.6
OCR_WORKER_QUEUE_MAX_MESSAGES=1
OCR_WORKER_PROCESSING_CONCURRENCY=1
OCR_WORKER_QUEUE_VISIBILITY_TIMEOUT=300

RESULTS_API_PORT=8080
RESULTS_API_SOURCE_ELECTION_ID=default
RESULTS_API_CORS_ORIGINS=*
RESULTS_API_KEY=
RESULTS_API_CANDIDATES_MANIFEST_URL=s3://ch7-static-bkkelection2569/api-data/candidates/manifest.json
RESULTS_API_CANDIDATES_FEATURED_URL=s3://ch7-static-bkkelection2569/api-data/candidates/featured.json
RESULTS_API_PARTIES_URL=s3://ch7-static-bkkelection2569/api-data/master-data/parties.json
RESULTS_API_CANDIDATES_TIMEOUT_SECONDS=5
RESULTS_API_CANDIDATES_CACHE_SECONDS=300
RESULTS_API_DISTRICTS_URL=s3://ch7-static-bkkelection2569/api-data/master-data/election-areas-bangkok.json
RESULTS_API_DISTRICTS_TIMEOUT_SECONDS=5
RESULTS_API_DISTRICTS_CACHE_SECONDS=300
RESULTS_API_ELECTION_ID=bkk-governor-2026
RESULTS_API_ELECTION_TITLE=ผลการเลือกตั้งผู้ว่าฯ กรุงเทพมหานคร
RESULTS_API_RESULT_STATUS=LIVE_COUNT
RESULTS_API_DELAYED_AFTER_MINUTES=30
GOVERNOR_RESULTS_PREFIX=api-data/governor-results-dev
RESULTS_API_DEFAULT_DATA_MODE=incremental_delta
RESULTS_API_STATIC_RESULTS_PREFIX=api-data/governor-results-dev
RESULTS_API_ENABLE_STATIC_FALLBACK=false

STATIC_RESULTS_PREFIX=api-data/governor-results-dev
STATIC_RESULTS_S3_BUCKET=ch7-static-bkkelection2569
STATIC_RESULTS_S3_REGION=

IMAGE_REGISTRY=election
IMAGE_TAG=local
